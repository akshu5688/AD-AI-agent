# AdAgent AI - Supabase Environment Variables Example
# Duplicate this file to '.env' and fill in your actual credentials.
# These will be automatically picked up by Vite's build compiler.

# Your Supabase Project API URL (found in Settings -> API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase Anon Public API Key (found in Settings -> API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
